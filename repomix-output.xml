<file path="apps/server/prisma/schema.prisma">
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  ADMIN_HR
  MANAGER
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum LeaveType {
  ANNUAL
  SICK
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

// ==========================================
// MODELS
// ==========================================

model Employee {
  id            Int            @id @default(autoincrement())
  fullName      String         @map("full_name")
  workEmail     String         @unique @map("work_email")
  passwordHash  String         @map("password_hash") // Nullable if using SSO, but required for now
  role          Role           @default(EMPLOYEE)  
  status        EmployeeStatus @default(ACTIVE) 
  
  // Job Info
  joinDate      DateTime       @map("join_date") @db.Date
  basicSalary   Decimal        @map("basic_salary") @db.Decimal(20, 2)
  departmentId  Int
  department    Department     @relation(fields: [departmentId], references: [id])
  jobTitle      String         @map("job_title")
  
  // Personal Info
  phone         String?        @map("phone_number")
  dob           DateTime?      @map("date_of_birth") @db.Date
  gender        String?
  address       String?
  emergencyName String?        @map("emergency_contact_name")
  emergencyPhone String?       @map("emergency_contact_phone")

  // Hierarchy (Self-Relation)
  managerId     Int?        @map("manager_id")
  manager       Employee?      @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates  Employee[]     @relation("ManagerSubordinates")

  // Relations
  attendance    Attendance[]
  leaveRequests LeaveRequest[] @relation("Requester")
  leaveDecisions LeaveRequest[] @relation("Decider")
  payrolls      Payroll[]
  
  // Audit Logs
  actionsPerformed AuditLog[] @relation("Actor")
  actionsTargeted  AuditLog[] @relation("Target")

  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("employees")
}

model Attendance {
  id          Int      @id @default(autoincrement())
  employeeId  Int   @map("employee_id")
  date        DateTime @db.Date
  
  // We use an Enum here for consistency with the API
  status      AttendanceStatus 
  
  checkInTime  DateTime? @map("check_in_time")
  checkOutTime DateTime? @map("check_out_time")
  
  workedDays  Decimal  @default(0) @map("worked_days") @db.Decimal(3, 1) // e.g. 1.0 or 0.5
  note        String?

  employee    Employee @relation(fields: [employeeId], references: [id])

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Constraint: One attendance record per employee per day
  @@unique([employeeId, date])
  @@map("attendance")
}

model LeaveRequest {
  id             Int         @id @default(autoincrement())
  employeeId     Int      @map("employee_id")
  leaveType      LeaveType   @map("leave_type")
  
  startDate      DateTime    @map("start_date") @db.Date
  endDate        DateTime    @map("end_date") @db.Date
  reason         String
  
  status         LeaveStatus @default(PENDING)
  rejectionReason String?    @map("rejection_note")
  
  // Approval Workflow
  decidedById    Int?     @map("decided_by")
  decidedAt      DateTime?   @map("decided_at")

  // Relations
  employee       Employee    @relation("Requester", fields: [employeeId], references: [id])
  decider        Employee?   @relation("Decider", fields: [decidedById], references: [id])

  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@map("leave_requests")
}

model Payroll {
  id                  Int      @id @default(autoincrement())
  employeeId          Int   @map("employee_id")
  
  // Time Period
  month               Int      // 1-12
  year                Int      // 2025
  
  // Snapshot Data (History Preservation)
  standardWorkingDays Int      @map("standard_working_days")
  actualWorkedDays    Decimal  @map("actual_worked_days") @db.Decimal(4, 1)
  snapshotBasicSalary Decimal  @map("snapshot_basic_salary") @db.Decimal(20, 2)
  
  // Calculated Components
  allowance           Decimal  @default(0) @db.Decimal(20, 2)
  bonus               Decimal  @default(0) @db.Decimal(20, 2)
  deduction           Decimal  @default(0) @db.Decimal(20, 2)
  netSalary           Decimal  @map("net_salary") @db.Decimal(20, 2)

  generatedAt         DateTime @default(now()) @map("generated_at")

  employee            Employee @relation(fields: [employeeId], references: [id])

  // Constraint: One payroll per employee per month
  @@unique([employeeId, month, year])
  @@map("payrolls")
}

model AuditLog {
  id               Int      @id @default(autoincrement())
  
  actorId          Int   @map("actor_id")
  targetEmployeeId Int?  @map("target_employee_id")
  
  actionType       String   @map("action_type") // e.g. "CREATE_EMPLOYEE", "APPROVE_LEAVE"
  timestamp        DateTime @default(now())
  
  // Storing changes as JSON is excellent for flexibility
  changesJson      Json?    @map("changes_json") 

  actor            Employee  @relation("Actor", fields: [actorId], references: [id])
  target           Employee? @relation("Target", fields: [targetEmployeeId], references: [id])

  @@map("audit_logs")
}

model Department {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  isActive   Boolean        @default(true)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  employees  Employee[] // relation back to employees

  @@map("departments")
}
